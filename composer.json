{
    "require": {
        "php": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.6",
        "guzzlehttp/guzzle": "^7.8"
    },
    "autoload": {
        "psr-4": {
            "RebuildConnector\\": "rebuildconnector/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RebuildConnector\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --stderr --bootstrap tests/bootstrap.php --testdox"
    },
    "config": {
        "platform": {
            "php": "7.4.33"
        }
    }
}
